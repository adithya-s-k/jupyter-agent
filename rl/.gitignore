# rl/-specific ignores. The top-level .gitignore covers __pycache__, .venv,
# .env, *.egg-info, logs/, etc. Only add things unique to this folder here.
# NOTE: gitignore does NOT support inline `#` comments — comments must be on
# their own line, otherwise the trailing text becomes part of the pattern.

# ── Data: heavy raw cache + generated artifacts ───────────────────────────
# Source dataset parquets (~70 GB).
data/raw/
# Classifier output (~few MB, regenerable from raw).
data/classified.parquet
# Stage-2/3 verification outputs (state.jsonl, trials/, etc.).
data/verification/
# Keep the human-readable summary reports — small and load-bearing.
!data/verification/**/REPORT.md
# data/splits/ IS committed — those IDs are the source of truth.
# Override the top-level *.parquet ignore for the split manifests only.
!data/splits/*.parquet
# Local snapshots of the splits before edits — kept on disk for safety, not in git.
data/splits/_backup/

# Per-condition ablation runs: keep decisions.csv + runs.csv (small + load-bearing)
# but exclude the per-run trial dirs which can be 5-10MB each.
data/ablation/*/runs/
data/ablation/*/logs/

# Local scratch + downloaded HF snapshots — regenerable.
cache/

# Generated Harbor task suites. Canonical home is the HF Hub dataset repo.
# Always regenerable via scripts/05_build_tasks.py (or legacy build_harbor_tasks.py).
harbor/tasks/

# `harbor run` job outputs (per-trial logs, configs, results).
jobs/

# Local harbor run logs we tee to files.
logs/

# ── Legacy archive: keep code in git, exclude heavy / regenerable blobs ───
_archive/cache-eval/
_archive/cache-sweep/
_archive/cache-misc/
_archive/jobs-v2/
_archive/logs/

# ── Tooling junk ──────────────────────────────────────────────────────────
.kaggle/
*.bak
.DS_Store

# ── Local IDE / editor state ──────────────────────────────────────────────
.idea/
.vscode/

# ── Local-only env override (defensive parity with top-level .gitignore) ──
.env
.env.local
